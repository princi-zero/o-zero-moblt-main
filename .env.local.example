# ─── Google Service Account (for Drive + Sheets) ─────────────────
# Get these from: console.cloud.google.com
#   → IAM & Admin → Service Accounts → your account → Keys → Add Key → JSON
#
# Enable these two APIs in the same project:
#   • Google Drive API
#   • Google Sheets API
#
# Share your Drive folder  → service account email → Editor
# Share your Google Sheet  → service account email → Editor

GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
# ─── Google Drive ─────────────────────────────────────────────────
# Folder ID from: drive.google.com/drive/folders/<FOLDER_ID>
GOOGLE_DRIVE_FOLDER_ID=
# ─── Google Sheets ────────────────────────────────────────────────
# Sheet ID from: docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=